{
  "build": {
    "beforeDevCommand": "pnpm run dev",
    "beforeBuildCommand": "pnpm run build",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420"
  },
  "bundle": {
    "active": true,
    "targets": ["appimage", "deb", "nsis", "dmg"],
    "macOS": {
      "minimumSystemVersion": "13.3",
      "signingIdentity": "-"
    },
    "shortDescription": "Choreo",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "productName": "Choreo",
  "version": "2024.2.3",
  "identifier": "org.sleipnirgroup",
  "plugins": {},
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "fullscreen": false,
        "resizable": true,
        "title": "Choreo v2024.2.3",
        "width": 1200,
        "height": 800
      }
    ],
    "security": {
      "capabilities": ["main-capability"],
      "csp": null
    }
  }
}
